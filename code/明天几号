    if (p.month == 2) {
        if ((p.year % 4 == 0 && p.year % 100 != 0) || p.year % 400 == 0) {
            if (p.day == 29) {
                i = 1;
            }
        }
    }
    if (p.day == month[p.month - 1]) {
        i = 1;
    }
    return (i == 1);
}

