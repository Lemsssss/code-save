数字金字塔
#include <stdio.h>
void pyramid(int n);
int main()
{
    int n;
    scanf_s("%d", &n);
    pyramid(n);
    return 0;
}
void pyramid(int n) {
    int i,j,k,a;
    a = n;
    for (i = 0;i<n;i++,a--) {  
        for (k=a-1;k!=0;k--) {
            printf(" ");
        }
        for (j =0;j<i+1;j++) {
         
            printf("%d ",i+1);
            
        }
            
         printf("\n");
    }
}

