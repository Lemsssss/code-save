int sq(int a, int b);
int devide(int a, int N);
int main(int argc, char const* argv[])
{
    int N, n, sum;

    scanf_s("%d", &N);
    n = sq(10, N - 1);
    while (n < sq(10, N)) {
        sum = devide(n, N);
        if (n == sum) {
            printf("%d\n", n);
        }
        n++;
    }

    return 0;
}
